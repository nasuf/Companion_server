datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "extensions")]
}

generator client {
  provider             = "prisma-client-py"
  previewFeatures      = ["postgresqlExtensions"]
  recursive_type_depth = 5
}

model User {
  id               String             @id @default(uuid())
  name             String
  email            String?            @unique
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  agents           AiAgent[]
  conversations    Conversation[]
  profile          UserProfile?
  portraits        UserPortrait[]
  memoryChangelogs MemoryChangelog[]
  intimacies       Intimacy[]
  timeTriggers     TimeTrigger[]

  @@map("users")
}

model AiAgent {
  id              String         @id @default(uuid())
  name            String
  userId          String         @map("user_id")
  user            User           @relation(fields: [userId], references: [id])
  personality     Json?
  sevenDimTraits  Json?          @map("seven_dim_traits")
  currentTraits   Json?          @map("current_traits")
  traitsHistory   Json?          @map("traits_history")
  background      String?
  values          Json?
  lifeOverview    String?        @map("life_overview")
  lifeOverviewData Json?         @map("life_overview_data")
  age             Int?
  occupation      String?
  city            String?
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  conversations   Conversation[]
  emotionState    AiEmotionState?
  schedules       AiDailySchedule[]
  intimacies      Intimacy[]
  proactiveLogs   ProactiveChatLog[]
  traitFeedbackLogs TraitFeedbackLog[]
  timeTriggers      TimeTrigger[]

  @@map("ai_agents")
}

model Conversation {
  id        String    @id @default(uuid())
  userId    String    @map("user_id")
  user      User      @relation(fields: [userId], references: [id])
  agentId   String    @map("agent_id")
  agent     AiAgent   @relation(fields: [agentId], references: [id])
  title     String?
  isDeleted Boolean   @default(false) @map("is_deleted")
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  messages  Message[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String       // "user" or "assistant"
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")

  @@map("messages")
}

model PromptTemplate {
  id             String   @id @default(uuid())
  key            String   @unique
  stage          String
  category       String
  title          String
  description    String?
  content        String
  defaultContent String   @map("default_content")
  isEnabled      Boolean  @default(true) @map("is_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("prompt_templates")
}

model UserMemory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String?  // "identity", "emotion", "preference", "life", "thought", "consolidated"
  level        Int      @default(3)
  content      String
  summary      String?
  importance   Float    @default(0.5)
  mentionCount Int      @default(0) @map("mention_count")
  isArchived   Boolean  @default(false) @map("is_archived")
  occurTime    DateTime? @map("occur_time")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("memories_user")
}

model AiMemory {
  id           String   @id @default(uuid())
  userId       String   @map("user_id")
  type         String?  // "identity", "emotion", "preference", "life", "thought", "consolidated"
  level        Int      @default(3)
  content      String
  summary      String?
  importance   Float    @default(0.5)
  mentionCount Int      @default(0) @map("mention_count")
  isArchived   Boolean  @default(false) @map("is_archived")
  occurTime    DateTime? @map("occur_time")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("memories_ai")
}

model UserProfile {
  id                String   @id @default(uuid())
  userId            String   @unique @map("user_id")
  user              User     @relation(fields: [userId], references: [id])
  traits            Json?
  interests         Json?
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  @@map("user_profiles")
}

model AiEmotionState {
  id        String   @id @default(uuid())
  agentId   String   @unique @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  pleasure  Float    @default(0.0) @map("pleasure")
  arousal   Float    @default(0.5)
  dominance Float    @default(0.5)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_emotion_states")
}

model UserPortrait {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  agentId   String   @map("agent_id")
  version   Int      @default(1)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_portraits")
}

model MemoryChangelog {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  memoryId  String   @map("memory_id")
  operation String   // "insert", "update", "delete"
  oldValue  String?  @map("old_value")
  newValue  String?  @map("new_value")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("memory_changelogs")
}

model Intimacy {
  id              String   @id @default(uuid())
  agentId         String   @map("agent_id")
  agent           AiAgent  @relation(fields: [agentId], references: [id])
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  topicIntimacy   Int      @default(50)  @map("topic_intimacy")
  topicLevel      String   @default("L3") @map("topic_level")
  topicUpdatedAt  DateTime @default(now()) @map("topic_updated_at")
  growthIntimacy  Int      @default(500) @map("growth_intimacy")
  growthLevel     String   @default("G5") @map("growth_level")
  growthUpdatedAt DateTime @default(now()) @map("growth_updated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId])
  @@map("intimacies")
}

model AiDailySchedule {
  id           String   @id @default(uuid())
  agentId      String   @map("agent_id")
  agent        AiAgent  @relation(fields: [agentId], references: [id])
  date         DateTime @db.Date
  scheduleData Json     @map("schedule_data")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([agentId, date])
  @@map("ai_daily_schedules")
}

model ScheduleAdjustLog {
  id         String   @id @default(uuid())
  agentId    String   @map("agent_id")
  adjustType String   @map("adjust_type")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("schedule_adjust_logs")
}

model ProactiveChatLog {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  userId    String   @map("user_id")
  message   String
  eventType String?  @map("event_type")
  createdAt DateTime @default(now()) @map("created_at")

  @@map("proactive_chat_logs")
}

model TraitFeedbackLog {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  dimension String
  delta     Float
  source    String   // "implicit" or "direct"
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("trait_feedback_logs")
}

model Sticker {
  id         Int      @id @default(autoincrement())
  url        String   @db.VarChar(255)
  emotionTags Json    @map("emotion_tags")  // [{"emotion":"高兴","weight":0.8}]
  intensity  Int      @default(3)           // 1~5
  style      String?  @db.VarChar(50)       // 幽默、可爱、严肃等
  tags       Json?                          // 场景标签 ["问候","安慰"]
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("stickers")
}

model TimeTrigger {
  id          String    @id @default(uuid())
  aiAgentId   String    @map("ai_agent_id")
  agent       AiAgent   @relation(fields: [aiAgentId], references: [id])
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  triggerTime DateTime  @map("trigger_time")
  repeatRule  String?   @map("repeat_rule")   // cron表达式，null=一次性
  actionType  String    @map("action_type")   // greeting/reminder/holiday/birthday
  actionData  Json?     @map("action_data")
  isActive    Boolean   @default(true) @map("is_active")
  lastFired   DateTime? @map("last_fired")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("time_triggers")
}
