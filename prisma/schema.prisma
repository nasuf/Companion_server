datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  directUrl  = env("DIRECT_DATABASE_URL")
  extensions = [pgvector(map: "vector", schema: "extensions")]
}

generator client {
  provider             = "prisma-client-py"
  previewFeatures      = ["postgresqlExtensions"]
  recursive_type_depth = 5
}

model User {
  id               String              @id @default(uuid())
  username         String              @unique
  hashedPassword   String              @map("hashed_password")
  role             String              @default("user") @map("role")
  email            String?             @unique
  status           String              @default("active")
  archivedAt       DateTime?           @map("archived_at")
  createdAt        DateTime            @default(now()) @map("created_at")
  updatedAt        DateTime            @updatedAt @map("updated_at")
  agents           AiAgent[]
  workspaces       ChatWorkspace[]
  conversations    Conversation[]
  profiles         UserProfile[]
  portraits        UserPortrait[]
  memoryChangelogs MemoryChangelog[]
  intimacies       Intimacy[]
  timeTriggers     TimeTrigger[]
  proactiveStates  ProactiveState[]
  proactiveEvents  ProactiveEventLog[]
  patienceStates   PatienceState[]
  bugReportsFiled    BugReport[] @relation("BugReportsFiled")
  bugReportsResolved BugReport[] @relation("BugReportsResolved")

  @@map("users")
}

model AiAgent {
  id                 String              @id @default(uuid())
  name               String
  userId             String              @map("user_id")
  user               User                @relation(fields: [userId], references: [id])
  status             String              @default("active")
  archivedAt         DateTime?           @map("archived_at")
  // Per spec §1.2: MBTI 是 canonical personality 表达，user 输入的 7 维仅作
  // 创建时的 transient 输入，转 MBTI 后即丢弃。
  mbti               Json? // 初始 MBTI: {EI, NS, TF, JP, type, summary}
  currentMbti        Json?               @map("current_mbti") // 调整后的 MBTI（同形）
  background         String?
  values             Json?
  lifeOverview       String?             @map("life_overview")
  age                Int?
  occupation         String?
  city               String?
  gender             String?             @map("gender")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  workspaces         ChatWorkspace[]
  conversations      Conversation[]
  emotionState       AiEmotionState?
  schedules          AiDailySchedule[]
  intimacies         Intimacy[]
  proactiveLogs      ProactiveChatLog[]
  traitFeedbackLogs  TraitFeedbackLog[]
  timeTriggers       TimeTrigger[]
  proactiveStates    ProactiveState[]
  proactiveEvents    ProactiveEventLog[]
  patienceStates     PatienceState[]

  @@map("ai_agents")
}

model ChatWorkspace {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  user            User                @relation(fields: [userId], references: [id])
  agentId         String?             @map("agent_id")
  agent           AiAgent?            @relation(fields: [agentId], references: [id])
  status          String              @default("active")
  archivedAt      DateTime?           @map("archived_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  conversations   Conversation[]
  userMemories    UserMemory[]
  aiMemories      AiMemory[]
  profiles        UserProfile[]
  changelogs      MemoryChangelog[]
  proactiveLogs   ProactiveChatLog[]
  proactiveState  ProactiveState?
  proactiveEvents ProactiveEventLog[]

  @@index([userId, status])
  @@index([agentId, status])
  @@map("chat_workspaces")
}

model Conversation {
  id              String              @id @default(uuid())
  userId          String              @map("user_id")
  user            User                @relation(fields: [userId], references: [id])
  agentId         String              @map("agent_id")
  agent           AiAgent             @relation(fields: [agentId], references: [id])
  workspaceId     String?             @map("workspace_id")
  workspace       ChatWorkspace?      @relation(fields: [workspaceId], references: [id])
  title           String?
  isDeleted       Boolean             @default(false) @map("is_deleted")
  archivedAt      DateTime?           @map("archived_at")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")
  messages        Message[]
  proactiveLogs   ProactiveChatLog[]
  proactiveStates ProactiveState[]
  proactiveEvents ProactiveEventLog[]

  @@map("conversations")
}

model Message {
  id             String       @id @default(uuid())
  conversationId String       @map("conversation_id")
  conversation   Conversation @relation(fields: [conversationId], references: [id])
  role           String // "user" or "assistant"
  content        String
  metadata       Json?
  createdAt      DateTime     @default(now()) @map("created_at")
  bugReports     BugReport[]

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("messages")
}

// Admin 测试时对单条 AI 回复打标的 bug 标签. 跟 Message 是 N:1
// (同一条消息可能踩到多类问题, 多次提报无重复约束).
// errorTypes 用 String[] 而非枚举: 类目随系统演化, 列表见
// Companion_web/src/lib/bugReportTypes.ts.
model BugReport {
  id           String    @id @default(uuid())
  messageId    String    @map("message_id")
  message      Message   @relation(fields: [messageId], references: [id], onDelete: Cascade)
  reporterId   String    @map("reporter_id")
  reporter     User      @relation("BugReportsFiled", fields: [reporterId], references: [id])
  errorTypes   String[]  @map("error_types")
  reason       String?
  status       String    @default("open") // "open" | "resolved"
  resolvedAt   DateTime? @map("resolved_at")
  resolvedById String?   @map("resolved_by_id")
  resolvedBy   User?     @relation("BugReportsResolved", fields: [resolvedById], references: [id])
  createdAt    DateTime  @default(now()) @map("created_at")

  @@index([messageId])
  @@index([status, createdAt(sort: Desc)])
  @@map("bug_reports")
}

// 本地 trace 镜像表. /traces/resolve/{message_id} 懒触发 share 后, 把
// LangSmith 的 enriched trace 树整份缓存到这里, 让 trace 详情页:
// 1. 不依赖 LangSmith 网络 (可读性 / 抽风容忍)
// 2. 不被 quota 限制 (batch trace 分析时不撞 LangSmith API 上限)
// 3. 可加 SQL 索引做趋势分析 (e.g. "哪个 prompt_key 平均耗时分位最高")
//
// 设计取舍:
// - traceId 做主键, 一条 trace 一行 (消息 → trace 是 1:1; sub_intent
//   通过 attach_to_parent 复用 parent traceId, 不另起 trace).
// - stepsJson 存 trace_enrich.enrich_steps 跑完的完整 step 数组 (含
//   inputs/outputs/decision_label/category/on_critical_path 等), 不展平
//   到列 — 字段多 + 可能演化, 列粒度太碎.
// - summaryJson 冗余存顶部 trace 摘要 (duration / tokens / message), 前端
//   常用字段不用每次解 stepsJson.
// - shareUrl 与 message.metadata.trace_url 重复, 但单独存便于按 trace 维度
//   查 (e.g. batch 分析).
model MessageTrace {
  traceId         String   @id @map("trace_id")
  conversationId  String   @map("conversation_id")
  messageId       String?  @map("message_id") // 关联 message 表; 不外键, 避免删 msg 级联
  rootMessage     String?  @map("root_message") // 用户原文 (从 trace.inputs.message)
  totalDurationMs Int?     @map("total_duration_ms")
  totalTokens     Int?     @map("total_tokens")
  llmStepCount    Int?     @map("llm_step_count")
  stepsJson       Json     @map("steps_json")
  summaryJson     Json     @map("summary_json")
  shareStatus     String   @default("pending") @map("share_status") // pending / shared / failed
  shareUrl        String?  @map("share_url")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@index([conversationId, createdAt(sort: Desc)])
  @@index([messageId])
  @@map("message_traces")
}

model PromptTemplate {
  id             String   @id @default(uuid())
  key            String   @unique
  stage          String
  category       String
  title          String
  description    String?
  content        String
  defaultContent String   @map("default_content")
  isEnabled      Boolean  @default(true) @map("is_enabled")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("prompt_templates")
}

model PromptTemplateVersion {
  id         String   @id @default(uuid())
  promptId   String   @map("prompt_id")
  promptKey  String   @map("prompt_key")
  content    String
  source     String
  changeType String   @map("change_type")
  createdAt  DateTime @default(now()) @map("created_at")

  @@index([promptId, createdAt(sort: Desc)])
  @@index([promptKey, createdAt(sort: Desc)])
  @@map("prompt_template_versions")
}

model UserMemory {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  workspaceId   String?        @map("workspace_id")
  workspace     ChatWorkspace? @relation(fields: [workspaceId], references: [id])
  type          String? // "identity", "emotion", "preference", "life", "thought", "consolidated"
  mainCategory  String?        @map("main_category")
  subCategory   String?        @map("sub_category")
  level         Int            @default(3)
  content       String
  summary       String?
  importance    Float          @default(0.5)
  mentionCount  Int            @default(0) @map("mention_count")
  isArchived    Boolean        @default(false) @map("is_archived")
  // Part 5 §3.1: occur_time = 事件实际发生时间 (= 时间解析器的 event_time)
  occurTime     DateTime?      @map("occur_time")
  // Part 5 §3.1: statement_time = 用户说出这句话的时间 (一般为消息接收时刻)
  statementTime DateTime?      @map("statement_time")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("memories_user")
}

model AiMemory {
  id            String         @id @default(uuid())
  userId        String         @map("user_id")
  workspaceId   String?        @map("workspace_id")
  workspace     ChatWorkspace? @relation(fields: [workspaceId], references: [id])
  type          String? // "identity", "emotion", "preference", "life", "thought", "consolidated"
  mainCategory  String?        @map("main_category")
  subCategory   String?        @map("sub_category")
  level         Int            @default(3)
  content       String
  summary       String?
  importance    Float          @default(0.5)
  mentionCount  Int            @default(0) @map("mention_count")
  isArchived    Boolean        @default(false) @map("is_archived")
  // Part 5 §3.1: occur_time = 事件实际发生时间 (= 时间解析器的 event_time)
  occurTime     DateTime?      @map("occur_time")
  // Part 5 §3.1: statement_time = 用户说出这句话的时间 (一般为消息接收时刻)
  statementTime DateTime?      @map("statement_time")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  @@map("memories_ai")
}

model UserProfile {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id])
  workspaceId String?        @unique @map("workspace_id")
  workspace   ChatWorkspace? @relation(fields: [workspaceId], references: [id])
  traits      Json?
  interests   Json?
  createdAt   DateTime       @default(now()) @map("created_at")
  updatedAt   DateTime       @updatedAt @map("updated_at")

  @@index([userId])
  @@map("user_profiles")
}

// Cache of last-computed AI PAD from chat turn (not authoritative state).
// Spec §3.2: 聊天热路径每条消息都通过 compute_ai_pad 重新计算 AI PAD，
// 结果回写此表供 (a) 下一条消息收到时的延迟计算 (§6.2 高情绪判定)
//            (b) Proactive 主动消息的 mood label
//            (c) GET /emotions/{agent_id}/current 读接口
model AiEmotionState {
  id        String   @id @default(uuid())
  agentId   String   @unique @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  pleasure  Float    @default(0.0) @map("pleasure")
  arousal   Float    @default(0.5)
  dominance Float    @default(0.5)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("ai_emotion_states")
}

model PatienceState {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  value     Int      @default(100)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId])
  @@map("patience_states")
}

model UserPortrait {
  id        String   @id @default(uuid())
  userId    String   @map("user_id")
  user      User     @relation(fields: [userId], references: [id])
  agentId   String   @map("agent_id")
  version   Int      @default(1)
  content   String
  createdAt DateTime @default(now()) @map("created_at")

  @@map("user_portraits")
}

model MemoryChangelog {
  id          String         @id @default(uuid())
  userId      String         @map("user_id")
  user        User           @relation(fields: [userId], references: [id])
  workspaceId String?        @map("workspace_id")
  workspace   ChatWorkspace? @relation(fields: [workspaceId], references: [id])
  memoryId    String         @map("memory_id")
  operation   String // "insert", "update", "delete"
  oldValue    String?        @map("old_value")
  newValue    String?        @map("new_value")
  createdAt   DateTime       @default(now()) @map("created_at")

  @@map("memory_changelogs")
}

model Intimacy {
  id              String   @id @default(uuid())
  agentId         String   @map("agent_id")
  agent           AiAgent  @relation(fields: [agentId], references: [id])
  userId          String   @map("user_id")
  user            User     @relation(fields: [userId], references: [id])
  topicIntimacy   Int      @default(50) @map("topic_intimacy")
  topicLevel      String   @default("L3") @map("topic_level")
  topicUpdatedAt  DateTime @default(now()) @map("topic_updated_at")
  growthIntimacy  Int      @default(500) @map("growth_intimacy")
  growthLevel     String   @default("G5") @map("growth_level")
  growthUpdatedAt DateTime @default(now()) @map("growth_updated_at")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId])
  @@map("intimacies")
}

model AiDailySchedule {
  id           String   @id @default(uuid())
  agentId      String   @map("agent_id")
  agent        AiAgent  @relation(fields: [agentId], references: [id])
  date         DateTime @db.Date
  scheduleData Json     @map("schedule_data")
  createdAt    DateTime @default(now()) @map("created_at")

  @@unique([agentId, date])
  @@map("ai_daily_schedules")
}

model ScheduleAdjustLog {
  id         String   @id @default(uuid())
  agentId    String   @map("agent_id")
  adjustType String   @map("adjust_type")
  oldValue   String?  @map("old_value")
  newValue   String?  @map("new_value")
  reason     String?
  createdAt  DateTime @default(now()) @map("created_at")

  @@map("schedule_adjust_logs")
}

model ProactiveChatLog {
  id             String         @id @default(uuid())
  agentId        String         @map("agent_id")
  agent          AiAgent        @relation(fields: [agentId], references: [id])
  userId         String         @map("user_id")
  workspaceId    String?        @map("workspace_id")
  workspace      ChatWorkspace? @relation(fields: [workspaceId], references: [id])
  conversationId String?        @map("conversation_id")
  conversation   Conversation?  @relation(fields: [conversationId], references: [id])
  message        String
  eventType      String?        @map("event_type")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([conversationId, createdAt])
  @@map("proactive_chat_logs")
}

model ProactiveState {
  id                      String              @id @default(uuid())
  workspaceId             String              @unique @map("workspace_id")
  workspace               ChatWorkspace       @relation(fields: [workspaceId], references: [id])
  userId                  String              @map("user_id")
  user                    User                @relation(fields: [userId], references: [id])
  agentId                 String              @map("agent_id")
  agent                   AiAgent             @relation(fields: [agentId], references: [id])
  conversationId          String?             @map("conversation_id")
  conversation            Conversation?       @relation(fields: [conversationId], references: [id])
  status                  String              @default("idle")
  stage                   String              @default("cold_start")
  silenceLevelN           Int                 @default(0) @map("silence_level_n")
  followupPlanType        String              @default("normal") @map("followup_plan_type")
  remainingForcedTriggers Int?                @map("remaining_forced_triggers")
  currentWindowIndex      Int?                @map("current_window_index")
  windowDueAt             DateTime?           @map("window_due_at")
  responseDeadlineAt      DateTime?           @map("response_deadline_at")
  t0At                    DateTime?           @map("t0_at")
  lastProactiveAt         DateTime?           @map("last_proactive_at")
  lastUserReplyAt         DateTime?           @map("last_user_reply_at")
  lastAssistantReplyAt    DateTime?           @map("last_assistant_reply_at")
  lastAttemptAt           DateTime?           @map("last_attempt_at")
  dailySceneTriggeredAt   DateTime?           @map("daily_scene_triggered_at")
  stopReason              String?             @map("stop_reason")
  metadata                Json?
  createdAt               DateTime            @default(now()) @map("created_at")
  updatedAt               DateTime            @updatedAt @map("updated_at")
  events                  ProactiveEventLog[]

  @@index([userId, status])
  @@index([agentId, status])
  @@index([status, windowDueAt])
  @@map("proactive_states")
}

model ProactiveEventLog {
  id             String         @id @default(uuid())
  stateId        String         @map("state_id")
  state          ProactiveState @relation(fields: [stateId], references: [id])
  workspaceId    String         @map("workspace_id")
  workspace      ChatWorkspace  @relation(fields: [workspaceId], references: [id])
  userId         String         @map("user_id")
  user           User           @relation(fields: [userId], references: [id])
  agentId        String         @map("agent_id")
  agent          AiAgent        @relation(fields: [agentId], references: [id])
  conversationId String?        @map("conversation_id")
  conversation   Conversation?  @relation(fields: [conversationId], references: [id])
  eventType      String         @map("event_type")
  windowIndex    Int?           @map("window_index")
  windowName     String?        @map("window_name")
  triggerType    String?        @map("trigger_type")
  payload        Json?          @map("payload")
  createdAt      DateTime       @default(now()) @map("created_at")

  @@index([workspaceId, createdAt])
  @@index([stateId, createdAt])
  @@index([eventType, createdAt])
  @@map("proactive_event_logs")
}

// DB-backed snapshot for Redis-primary proactive counters (proactive_count:{aid}:{uid}:{YYYYMMDD}).
// Redis 挂时 can_send_proactive / can_send_proactive_2day 可从这里降级读取, 避免计数丢失
// 导致主动消息超发. date 按 Asia/Shanghai 时区的 YYYYMMDD 字符串, 与 Redis key 对齐.
model ProactiveCounter {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  userId    String   @map("user_id")
  date      String
  count     Int      @default(0)
  updatedAt DateTime @updatedAt @map("updated_at")

  @@unique([agentId, userId, date])
  @@index([agentId, userId])
  @@map("proactive_counters")
}

model TraitFeedbackLog {
  id        String   @id @default(uuid())
  agentId   String   @map("agent_id")
  agent     AiAgent  @relation(fields: [agentId], references: [id])
  dimension String
  delta     Float
  source    String // "implicit" or "direct"
  reason    String?
  createdAt DateTime @default(now()) @map("created_at")

  @@map("trait_feedback_logs")
}

model Sticker {
  id          Int      @id @default(autoincrement())
  url         String   @db.VarChar(255)
  emotionTags Json     @map("emotion_tags") // [{"emotion":"高兴","weight":0.8}]
  intensity   Int      @default(3) // 1~5
  style       String?  @db.VarChar(50) // 幽默、可爱、严肃等
  tags        Json? // 场景标签 ["问候","安慰"]
  createdAt   DateTime @default(now()) @map("created_at")

  @@map("stickers")
}

// ── AI 职业背景设定 ──

model CareerTemplate {
  id          String   @id @default(uuid())
  title       String // 职业
  duties      String // 工作内容
  socialValue String   @map("social_value") // 社会价值
  clients     String // 服务对象
  status      String   @default("active") // active / archived
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@map("career_templates")
}

// Plan B 后已删除 CharacterTemplate / CharacterProfile (admin 不再批量预生
// 背景, agent 创建时即时单步 LLM 生成 — services/character_generation.py).

model TimeTrigger {
  id          String    @id @default(uuid())
  aiAgentId   String    @map("ai_agent_id")
  agent       AiAgent   @relation(fields: [aiAgentId], references: [id])
  userId      String    @map("user_id")
  user        User      @relation(fields: [userId], references: [id])
  triggerTime DateTime  @map("trigger_time")
  repeatRule  String?   @map("repeat_rule") // cron表达式，null=一次性
  actionType  String    @map("action_type") // greeting/reminder/holiday/birthday
  actionData  Json?     @map("action_data")
  isActive    Boolean   @default(true) @map("is_active")
  lastFired   DateTime? @map("last_fired")
  createdAt   DateTime  @default(now()) @map("created_at")

  @@map("time_triggers")
}

// ── Entity knowledge layer ──

model MemoryEntity {
  id              String    @id @default(uuid())
  userId          String    @map("user_id")
  workspaceId     String?   @map("workspace_id")
  canonicalName   String    @map("canonical_name") // "妈妈" / "老王" / "杭州"
  aliases         String[]  @default([]) // ["妈","我妈","妈咪"]
  entityType      String    @map("entity_type") // person / place / org / pet / topic / preference / other
  role            String? // mother / colleague / hometown / ...
  mentionCount    Int       @default(0) @map("mention_count")
  lastMentionedAt DateTime? @map("last_mentioned_at")
  isArchived      Boolean   @default(false) @map("is_archived")
  metadata        Json? // 可选扩展（e.g. preference.value）
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  mentions MemoryMention[]

  @@unique([userId, workspaceId, entityType, canonicalName])
  @@index([userId, workspaceId, entityType])
  @@index([userId, workspaceId, mentionCount])
  @@index([userId, workspaceId, isArchived, lastMentionedAt])
  @@map("memory_entities")
}

model MemoryMention {
  memoryId     String       @map("memory_id")
  memorySource String       @map("memory_source") // "user" | "ai"
  entityId     String       @map("entity_id")
  entity       MemoryEntity @relation(fields: [entityId], references: [id], onDelete: Cascade)
  userId       String       @map("user_id")
  workspaceId  String?      @map("workspace_id")
  createdAt    DateTime     @default(now()) @map("created_at")

  @@id([memoryId, entityId])
  @@index([entityId])
  @@index([userId, workspaceId])
  @@index([memoryId])
  @@map("memory_mentions")
}

// ── Calendar / 节假日 ──
//
// 来源:
//   chinesecalendar  (CN 法定假日 + 调休, 年度数据随国务院办公厅通知发布更新)
//   nager            (国际节日, nager.date REST API)
//   local            (算法计算的国际纪念日, 妇女节/儿童节/母亲节/父亲节)
//   manual           (admin 手动录入或从老硬编码 seed 的条目, refresh 不覆盖)
//
// country_code: ISO-3166 alpha-2 (如 "CN"); "INTL" 表示无特定国家的国际纪念日.
model Holiday {
  id            String   @id @default(uuid())
  date          DateTime @db.Date
  name          String
  type          String // legal / traditional / international / custom
  countryCode   String   @default("CN") @map("country_code")
  isWorkdaySwap Boolean  @default(false) @map("is_workday_swap")
  source        String // chinesecalendar / nager / local / manual
  metadata      Json?
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  @@unique([date, countryCode, name])
  @@index([date])
  @@index([countryCode])
  @@index([source])
  @@map("holidays")
}
