DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
REDIS_URL="redis://localhost:6379/0"
NEO4J_URI="bolt://localhost:7687"
NEO4J_USER="neo4j"
NEO4J_PASSWORD="your_neo4j_password"

# Local Ollama
OLLAMA_BASE_URL="http://localhost:11434"

# Alibaba Cloud Bailian / DashScope
DASHSCOPE_API_KEY=""
DASHSCOPE_BASE_URL="https://dashscope.aliyuncs.com/compatible-mode/v1"
DASHSCOPE_ENABLE_THINKING="false"

# Simple switch
ONLINE_MODEL="false"

# Only four model names you normally need to care about
LOCAL_CHAT_MODEL="qwen2.5:14b"
LOCAL_SMALL_MODEL="qwen2.5:7b"
REMOTE_CHAT_MODEL="qwen3.5-plus"
REMOTE_SMALL_MODEL="qwen3.5-flash"

# Optional advanced overrides. Leave blank unless debugging a special case.
CHAT_MODEL=""
SUMMARIZER_MODEL=""
UTILITY_MODEL=""
EMBEDDING_MODEL=""
CHAT_PROVIDER=""
SUMMARIZER_PROVIDER=""
UTILITY_PROVIDER=""
EMBEDDING_PROVIDER=""
LLM_PROVIDER=""

LANGSMITH_TRACING="false"
LANGSMITH_API_KEY=""
